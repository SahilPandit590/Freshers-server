<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"/>
  <title>Freshers Gallery - <%= roll %></title>

  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  
  <!-- Mobile Optimization -->
  <meta name="theme-color" content="#0d6efd">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  
  <style>
    :root {
      --img-height: 160px;
    }
    @media (max-width: 576px) {
      :root { --img-height: 140px; }
      .card-title { font-size: 0.9rem; }
      .download-btn { font-size: 0.8rem; padding: 0.4rem; }
    }

    body {
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      touch-action: manipulation;
    }

    .gallery-img {
      width: 100%;
      height: var(--img-height);
      object-fit: cover;
      border-radius: 10px;
      transition: transform 0.25s ease;
      image-rendering: -webkit-optimize-contrast;
    }
    .gallery-img:active {
      transform: scale(0.98);
    }

    .card {
      border: none;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      transition: all 0.3s ease;
      background: #fff;
    }
    .card:hover {
      box-shadow: 0 8px 20px rgba(0,0,0,0.15);
      transform: translateY(-2px);
    }

    .download-btn {
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .container {
      padding-bottom: 80px; /* Space for mobile bottom bar */
    }

    /* Prevent zoom on input focus (iOS) */
    input, select, textarea {
      font-size: 16px !important;
    }
  </style>
</head>
<body class="bg-light">

  <div class="container py-4 py-md-5">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1 class="h4 h3-md text-primary mb-0">Gallery - <%= roll %></h1>
      <a href="/logout" class="btn btn-outline-danger btn-sm">Logout</a>
    </div>

    <!-- Gallery -->
    <% if (images && images.length > 0) { %>
      <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 g-3 g-md-4">
        <% images.forEach(img => { %>
          <div class="col">
            <div class="card h-100">
              <a href="<%= img.full %>" target="_blank" class="d-block text-decoration-none">
                <img 
                  src="<%= img.thumb %>" 
                  class="gallery-img card-img-top" 
                  alt="<%= img.name %>"
                  loading="lazy"
                  onerror="this.src='https://via.placeholder.com/300x200?text=Image+Not+Found'"
                >
              </a>
              <div class="card-body text-center p-2 p-md-3">
                <h5 class="card-title mb-1"><%= img.name %></h5>
                <a href="<%= img.full %>" download class="btn btn-success btn-sm download-btn w-100 mt-2">
                  Download
                </a>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="text-center py-5">
        <div class="alert alert-info d-inline-block p-4">
          <strong>No images yet!</strong><br>
          <small class="text-muted">Check back later or contact admin.</small>
        </div>
      </div>
    <% } %>
  </div>

  <!-- Bootstrap + Lazy Load -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Lazy load fallback (if browser doesn't support native)
    document.addEventListener("DOMContentLoaded", function() {
      const images = document.querySelectorAll("img[loading='lazy']");
      if ("loading" in HTMLImageElement.prototype) return;

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const img = entry.target;
            img.src = img.dataset.src || img.src;
            observer.unobserve(img);
          }
        });
      });
      images.forEach(img => observer.observe(img));
    });
  </script>
</body>
</html>